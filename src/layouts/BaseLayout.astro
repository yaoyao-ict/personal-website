---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "antd/dist/reset.css";
import "../styles/global.css";

const {
  title = "YaoYao",
  description = "YaoYao's personal website, featuring projects, writing, experience, and contact information.",
  home = false,
  titleKey = "title.home",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body data-title-key={titleKey}>
    <Header home={home} />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline src="/scripts/site.js"></script>
  </body>
</html>
