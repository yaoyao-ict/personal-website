---
const { cards } = Astro.props;
---

<div class="card-grid">
  {cards.map((card) => (
    <a class="content-card" href={card.href}>
      <span>{card.eyebrow}</span>
      <strong data-i18n={card.titleKey}>{card.title}</strong>
      <p data-i18n={card.descriptionKey}>{card.description}</p>
    </a>
  ))}
</div>
