---
import { navigation } from "../data/navigation.js";

const { home = false } = Astro.props;

const icons = {
  book: "M4 19.5V5.75A2.75 2.75 0 0 1 6.75 3H20v16H6.75A2.75 2.75 0 0 0 4 21.75V19.5Zm3-14V17h11V5.5H7Z",
  chart: "M4 19h16v2H2V3h2v16Zm4-2H6v-6h2v6Zm5 0h-2V7h2v10Zm5 0h-2v-9h2v9Z",
  folder: "M3 6.5A2.5 2.5 0 0 1 5.5 4H10l2 2h8.5A2.5 2.5 0 0 1 23 8.5v8A2.5 2.5 0 0 1 20.5 19h-16A2.5 2.5 0 0 1 2 16.5v-10h1Zm2.5.5A.5.5 0 0 0 5 7.5v9a.5.5 0 0 0 .5.5h15a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5H11.2l-2-2H5.5Z",
  grid: "M4 4h7v7H4V4Zm9 0h7v7h-7V4ZM4 13h7v7H4v-7Zm9 0h7v7h-7v-7Z",
  growth: "M4 18h17v2H2V4h2v14Zm2.5-3.5 4.25-4.25 3 3L20 7l1.4 1.4-7.65 7.65-3-3L7.9 15.9l-1.4-1.4Z",
  mail: "M4.5 5h15A2.5 2.5 0 0 1 22 7.5v9A2.5 2.5 0 0 1 19.5 19h-15A2.5 2.5 0 0 1 2 16.5v-9A2.5 2.5 0 0 1 4.5 5Zm.2 2 7.3 5.15L19.3 7H4.7Zm17.3 9.5V8.9l-10 7.05-10-7.05v7.6c0 .28.22.5.5.5h19c.28 0 .5-.22.5-.5Z",
  pen: "M17.75 3.25a2.4 2.4 0 0 1 3.4 3.4L9.2 18.6 4 20l1.4-5.2L17.75 3.25Zm1.4 1.4a.42.42 0 0 0-.6 0L7.2 16l-.45 1.75L8.5 17.3 19.15 6.95a.42.42 0 0 0 0-.6Z",
  rocket: "M13.5 3.2c2.9-.45 5.55.2 7.3 1.95 1.75 1.75 2.4 4.4 1.95 7.3l-4.2 1.4-4.4 4.4-2.4-2.4-3.3 1.05 1.05-3.3-2.4-2.4 4.4-4.4 1.5-4.3.5-.3Zm1.05 2.05-.95 2.75-4.05 4.05 2.4 2.4-.25.8.8-.25 2.4 2.4 4.05-4.05 2.75-.95c.2-2.2-.32-4.1-1.55-5.33-1.23-1.23-3.12-1.75-5.3-1.55l-.3.03ZM5 16.5c1.1.18 2.2.72 2.95 1.47.75.75 1.3 1.85 1.47 2.95-1.8.4-3.98.12-5.2-1.1-1.22-1.22-1.5-3.4-1.1-5.2.3.45.8.95 1.38 1.43.18.14.35.31.5.45Z",
  user: "M12 12a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9Zm0-2a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Zm8 11H4v-1.5A6.5 6.5 0 0 1 10.5 13h3A6.5 6.5 0 0 1 20 19.5V21Zm-13.8-2h11.6A4.5 4.5 0 0 0 13.5 15h-3a4.5 4.5 0 0 0-4.3 4Z",
  zap: "M13 2 4 13h7l-1 9 9-12h-7l1-8Z",
};
---

<header class:list={["site-header", !home && "compact-header"]}>
  <a class="brand" href="/" aria-label="Home" data-i18n-aria="aria.home">
    <span>Yao</span>
    <span class="spark">W</span>
    <span>Yao</span>
  </a>

  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav" data-i18n="button.menu">
    Menu
  </button>

  <nav class="main-nav" id="main-nav" aria-label="Main navigation" data-i18n-aria="aria.mainNav">
    {navigation.map((group) => (
      group.links ? (
        <div class="nav-menu">
          <button type="button" class="nav-menu-trigger" aria-expanded="false">
            <span class="nav-label">
              <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d={icons[group.icon]} /></svg>
              <span data-i18n={group.key}>{group.label}</span>
            </span>
          </button>
          <div class="dropdown">
            {group.links.map((link) => (
              <a href={link.href}>
                <svg class="dropdown-icon" viewBox="0 0 24 24" aria-hidden="true"><path d={icons[link.icon]} /></svg>
                <span data-i18n={link.key}>{link.label}</span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a class="nav-direct-link" href={group.href}>
          <span class="nav-label">
            <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true"><path d={icons[group.icon]} /></svg>
            <span data-i18n={group.key}>{group.label}</span>
          </span>
        </a>
      )
    ))}
  </nav>

  <div class="header-tools" aria-label="Site tools" data-i18n-aria="aria.siteTools">
    <div class="nav-menu utility-menu">
      <button type="button" class="nav-menu-trigger" aria-expanded="false" data-language-trigger data-i18n="label.language">
        Language
      </button>
      <div class="dropdown utility-dropdown">
        <button type="button" data-language-option="en">English</button>
        <button type="button" data-language-option="zh">中文</button>
      </div>
    </div>
    <button class="icon-button" type="button" data-open-search aria-label="Search" data-i18n="button.search" data-i18n-aria="button.search">Search</button>
    <button class="icon-button" type="button" data-theme aria-label="Toggle theme" data-i18n="button.theme" data-i18n-aria="button.theme">Theme</button>
  </div>
</header>
