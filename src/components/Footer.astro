---
const footerLinks = [
  { label: "Projects", key: "nav.projects", href: "/projects/" },
  { label: "Writing", key: "nav.writing", href: "/writing/" },
  { label: "About", key: "nav.about", href: "/about/" },
  { label: "Contact", key: "nav.about.contact", href: "/contact/" },
  { label: "GitHub", href: "https://github.com/yaoyao-ict" },
];
---

<footer class="site-footer">
  <a class="brand footer-brand" href="/">Yao<span class="spark">W</span>Yao</a>
  <nav class="footer-links" aria-label="Footer navigation">
    {footerLinks.map((link) => (
      <a href={link.href} data-i18n={link.key}>{link.label}</a>
    ))}
  </nav>
  <p class="copyright" data-i18n="footer.copyright">Copyright 2026 YaoYao. All rights reserved.</p>
</footer>
