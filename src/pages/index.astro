---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import HomeTimeline from "../components/react/HomeTimeline.jsx";
import ShowMoreButton from "../components/react/ShowMoreButton.jsx";
import { homeTimeline } from "../data/navigation.js";
---

<BaseLayout title="YaoYao" titleKey="title.home" home>
  <Hero />

  <section id="latest" class="home-feed" aria-labelledby="feed-title">
    <p class="eyebrow" data-i18n="home.feed.eyebrow">Latest</p>
    <h1 id="feed-title" data-i18n="home.feed.title">Articles and Tutorials</h1>
    <p class="home-feed-lead" data-i18n="home.feed.lead">
      Recent writing, tutorials, and project notes are organized here in reverse chronological order.
    </p>
    <p class="search-summary" data-search-summary hidden></p>
    <p class="search-empty" data-search-empty data-i18n="search.empty" hidden>No results found. Try a different keyword.</p>

    <HomeTimeline items={homeTimeline} client:load />

    <ShowMoreButton client:load />
  </section>
</BaseLayout>
