---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout title="Contact | YaoYao" titleKey="title.contact">
  <section class="page-shell">
    <PageHeader
      eyebrow="Contact"
      title="Contact"
      titleKey="page.contact.title"
      lead="A simple place to find public links and future collaboration details."
      leadKey="page.contact.lead"
    />
    <div class="card-grid">
      <a class="content-card" href="https://github.com/yaoyao-ict">
        <span>GitHub</span>
        <strong>yaoyao-ict</strong>
        <p data-i18n="page.contact.github">View code, projects, and the website repository.</p>
      </a>
      <a class="content-card" href="/projects/">
        <span data-i18n="page.contact.projectsLabel">Projects</span>
        <strong data-i18n="page.contact.projectsTitle">Project work</strong>
        <p data-i18n="page.contact.projects">Browse selected projects around dashboards, automation, and product experience.</p>
      </a>
      <a class="content-card" href="/writing/">
        <span data-i18n="page.contact.writingLabel">Writing</span>
        <strong data-i18n="page.contact.writingTitle">Notes and essays</strong>
        <p data-i18n="page.contact.writing">Read notes about deployment, portfolio storytelling, and building this site.</p>
      </a>
    </div>
  </section>
</BaseLayout>
