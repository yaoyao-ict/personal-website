---
import ArticleLayout from "../../layouts/ArticleLayout.astro";

const toc = [
  { id: "background", label: "Background", key: "article.section.background" },
  { id: "work", label: "How I Work", key: "article.section.work" },
  { id: "focus", label: "Current Focus", key: "article.section.focus" },
  { id: "contact", label: "Contact", key: "article.contact.title" },
];
---

<ArticleLayout
  title="About YaoYao"
  titleKey="article.aboutYaoYao.title"
  subtitle="A personal profile covering how I work, what I care about, and what I am building toward."
  subtitleKey="article.aboutYaoYao.description"
  eyebrow="About"
  toc={toc}
>
  <section id="background">
    <h2 data-i18n="article.section.background">Background</h2>
    <p data-i18n="article.aboutYaoYao.background">
      I am building this site as a clearer home for projects, writing, technical notes, and the story behind the work.
    </p>
    <p data-i18n="article.aboutYaoYao.backgroundDetail">
      The goal is to make my experience easier to browse: what I have built, how I think through problems, and what kind of work I want to keep growing into.
    </p>
  </section>

  <section id="work">
    <h2 data-i18n="article.section.work">How I Work</h2>
    <p data-i18n="article.aboutYaoYao.work">
      I like to clarify complex problems, build reliable workflows, and keep improving experiences that users can actually feel.
    </p>
    <p data-i18n="article.aboutYaoYao.workDetail">
      I care about structure, maintainability, and communication: turning scattered requirements into a plan, then making the result understandable for both technical and non-technical collaborators.
    </p>
  </section>

  <section id="focus">
    <h2 data-i18n="article.section.focus">Current Focus</h2>
    <p data-i18n="article.aboutYaoYao.focus">
      This site will gradually collect work around product experience, data dashboards, workflow automation, and maintainable web systems.
    </p>
    <p data-i18n="article.aboutYaoYao.focusDetail">
      The first version focuses on a few representative themes instead of trying to document everything at once.
    </p>
  </section>

  <section id="contact">
    <h2 data-i18n="article.contact.title">Contact</h2>
    <p data-i18n="article.contact.description">
      The best current contact path is GitHub. More contact links can be added here when they are ready to publish.
    </p>
    <div class="contact-links article-contact-links">
      <a href="https://github.com/yaoyao-ict">GitHub</a>
      <a href="/contact/">Contact page</a>
    </div>
  </section>
</ArticleLayout>
