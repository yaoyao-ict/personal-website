---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import DetailCard from "../../components/DetailCard.astro";
---

<BaseLayout title="About | YaoYao" titleKey="title.about">
  <section class="page-shell">
    <PageHeader
      eyebrow="About"
      title="About YaoYao"
      titleKey="page.about.title"
      lead="A fuller introduction can live here: background, experience, working style, and current focus."
      leadKey="page.about.lead"
    />
    <DetailCard title="How I Work" titleKey="detail.about.title">
      <p data-i18n="detail.about.description">
        I like to clarify complex problems, build reliable workflows, and keep improving experiences that users can feel.
      </p>
    </DetailCard>
  </section>
</BaseLayout>
