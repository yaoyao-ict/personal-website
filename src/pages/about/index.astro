---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import CollectionList from "../../components/CollectionList.astro";
import { aboutArticles } from "../../data/navigation.js";
---

<BaseLayout title="About | YaoYao" titleKey="title.about">
  <section class="page-shell">
    <PageHeader
      eyebrow="About"
      title="About"
      titleKey="page.about.title"
      lead="Personal information, working style, contact links, and the context behind this website live here."
      leadKey="page.about.lead"
    />
    <CollectionList countLabel="2 Pages" countKey="collection.about.count" items={aboutArticles} />
  </section>
</BaseLayout>
