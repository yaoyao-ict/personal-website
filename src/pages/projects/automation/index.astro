---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import DetailCard from "../../../components/DetailCard.astro";
---

<BaseLayout title="Automation Projects | YaoYao" titleKey="title.projects.automation">
  <section class="page-shell">
    <PageHeader
      eyebrow="Automation"
      title="Automation Projects"
      titleKey="page.projects.automation.title"
      lead="Projects related to Python, APIs, Azure, internal tools, and workflow automation."
      leadKey="page.projects.automation.lead"
    />
    <DetailCard title="Automation Workflow" titleKey="detail.automation.title">
      <p data-i18n="detail.automation.description">
        Breaking repetitive tasks into reliable steps, then connecting them through scripts and services.
      </p>
    </DetailCard>
  </section>
</BaseLayout>
