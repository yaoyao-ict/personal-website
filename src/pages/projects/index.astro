---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import CardGrid from "../../components/CardGrid.astro";
import { projectCards } from "../../data/navigation.js";
---

<BaseLayout title="Projects | YaoYao" titleKey="title.projects">
  <section class="page-shell">
    <PageHeader
      eyebrow="Projects"
      title="Project Index"
      titleKey="page.projects.title"
      lead="Projects are organized by theme. The homepage highlights selected work, while each category has its own page."
      leadKey="page.projects.lead"
    />
    <CardGrid cards={projectCards} />
  </section>
</BaseLayout>
