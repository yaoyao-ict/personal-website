---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import DetailCard from "../../../components/DetailCard.astro";
---

<BaseLayout title="Data Projects | YaoYao" titleKey="title.projects.data">
  <section class="page-shell">
    <PageHeader
      eyebrow="Data"
      title="Data Dashboards"
      titleKey="page.projects.data.title"
      lead="Projects around data visualization, reporting, monitoring, and decision support."
      leadKey="page.projects.data.lead"
    />
    <DetailCard title="Smart Dashboard" titleKey="detail.data.title">
      <p data-i18n="detail.data.description">
        Turning key metrics into views that are easy to scan, compare, and act on.
      </p>
    </DetailCard>
  </section>
</BaseLayout>
