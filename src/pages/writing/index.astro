---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import CardGrid from "../../components/CardGrid.astro";
import { writingCards } from "../../data/navigation.js";
---

<BaseLayout title="Writing | YaoYao" titleKey="title.writing">
  <section class="page-shell">
    <PageHeader
      eyebrow="Writing"
      title="Writing Index"
      titleKey="page.writing.title"
      lead="Notes and essays are grouped by topic. The homepage shows only the most recent pieces."
      leadKey="page.writing.lead"
    />
    <CardGrid cards={writingCards} />
  </section>
</BaseLayout>
