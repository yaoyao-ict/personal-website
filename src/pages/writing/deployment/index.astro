---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import DetailCard from "../../../components/DetailCard.astro";
---

<BaseLayout title="Deployment Notes | YaoYao" titleKey="title.writing.deployment">
  <section class="page-shell">
    <PageHeader
      eyebrow="Deployment"
      title="Deployment Notes"
      titleKey="page.writing.deployment.title"
      lead="Notes about building this site locally and publishing it with GitHub Pages."
      leadKey="page.writing.deployment.lead"
    />
    <DetailCard title="GitHub Pages Publishing Flow" titleKey="detail.deployment.title">
      <p data-i18n="detail.deployment.description">
        After naming the repository <code>yaoyao-ict.github.io</code>, the site can be published at the root domain.
      </p>
    </DetailCard>
  </section>
</BaseLayout>
