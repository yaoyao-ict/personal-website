---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import DetailCard from "../../../components/DetailCard.astro";
---

<BaseLayout title="Career Growth | YaoYao" titleKey="title.writing.career">
  <section class="page-shell">
    <PageHeader
      eyebrow="Career"
      title="Career Growth"
      titleKey="page.writing.career.title"
      lead="Writing about portfolio work, project storytelling, collaboration, and reflection."
      leadKey="page.writing.career.lead"
    />
    <DetailCard title="Writing Projects as Real Work" titleKey="detail.career.title">
      <p data-i18n="detail.career.description">
        A strong project page focuses on the problem, decisions, process, and results rather than a timeline of tasks.
      </p>
    </DetailCard>
  </section>
</BaseLayout>
